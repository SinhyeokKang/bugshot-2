exports[`본문 출력 골든 — 기본 순서 > buildIssueHtml > element 모드 + 전체 로그 1`] = `
"<!-- bugshot-meta-for-ai
{
  "version": 1,
  "captureMode": "element",
  "url": "https://example.com/page",
  "capturedAt": 1700000000000,
  "os": "macOS 15.5",
  "browser": "Chrome 138",
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "environment": {
    "Locale": "ko-KR"
  },
  "selector": "div.container > button",
  "tagName": "button",
  "classListBefore": [
    "btn"
  ],
  "classListAfter": [
    "btn",
    "btn-primary"
  ],
  "specifiedStyles": {
    "color": "#000"
  },
  "cssChanges": [
    {
      "property": "color",
      "from": "#000",
      "to": "#fff"
    },
    {
      "property": "class",
      "from": "btn",
      "to": "btn btn-primary"
    }
  ],
  "tokens": [
    {
      "name": "--brand",
      "value": "#4f46e5"
    }
  ]
}
-->
<h1>Golden Issue</h1>
<h2>md.section.env</h2>
<ul>
<li><strong>OS</strong>: macOS 15.5</li>
<li><strong>Browser</strong>: Chrome 138</li>
<li><strong>Page</strong>: https://example.com/page</li>
<li><strong>DOM</strong>: <code>div.container &gt; button</code></li>
<li><strong>Viewport</strong>: 1920×1080</li>
<li><strong>Captured</strong>: 2023-11-14 22:13:20 GMT+9</li>
<li><strong>Locale</strong>: ko-KR</li>
</ul>
<h2>md.section.description</h2>
<p>버튼이 눌리지 않음</p>

<h2>md.section.stepsToReproduce</h2>
<ol><li>1단계 진입</li><li>2단계 클릭</li></ol>
<h2>md.section.styleChanges (div.container &gt; button)</h2>
<table><thead><tr><th>md.column.property</th><th>As is</th><th>To be</th></tr></thead><tbody>
<tr><td>color</td><td>#000</td><td>#fff</td></tr>
<tr><td>class</td><td>btn</td><td>btn <strong>btn-primary</strong></td></tr>
</tbody></table>
<h2>logSummary.title</h2>
<p><strong>logSummary.logs.lead</strong> logSummary.logs.detail file=logs.html</p>
<ul>
<li>logSummary.network.line n=12 errors=1</li>
<li>logSummary.console.line n=8 errors=2 warns=1</li>
<li>logSummary.action.line n=5</li>
</ul>
<h2>md.section.expectedResult</h2>
<p>버튼이 눌린다</p>

<hr>
<p><em>Reported via <a href="https://bug-shot.com">BugShot</a></em></p>"
`;

