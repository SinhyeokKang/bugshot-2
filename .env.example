# Atlassian OAuth 3LO 설정
# 이 파일은 커밋된다. 실제 값은 .env.local에 작성한다.

VITE_ATLASSIAN_CLIENT_ID=
VITE_OAUTH_PROXY_URL=

# GitHub OAuth (Web Flow). dev/prod App 분리 운영.
# - 일반 빌드: VITE_GITHUB_CLIENT_ID (dev App의 client_id) 사용
# - BUGSHOT_STORE_BUILD=1 (스토어 빌드): VITE_GITHUB_CLIENT_ID_PROD가
#   빌드 시점에 VITE_GITHUB_CLIENT_ID로 define-치환 (vite.config.ts).
# 비어있으면 OAuth 버튼 비활성화, PAT 인증만 가능.
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_CLIENT_ID_PROD=

# Linear OAuth (PKCE, proxy 불필요).
# 비어있으면 OAuth 버튼 비활성화, API Key 인증만 가능.
VITE_LINEAR_CLIENT_ID=

# Notion OAuth (proxy 경유, public integration).
# Notion App 1개에 dev/prod redirect URI 둘 다 등록 가능 → 단일 client_id 사용.
# 비어있으면 OAuth 버튼 비활성화, Internal Token 인증만 가능.
VITE_NOTION_CLIENT_ID=

# GitLab OAuth (PKCE, proxy 불필요, gitlab.com 한정).
# App 1개에 dev/prod redirect URI 둘 다 등록 → 단일 client_id 사용.
# 비어있으면 OAuth 버튼 비활성화, PAT 인증만 가능.
VITE_GITLAB_CLIENT_ID=

# Asana OAuth.
# App 1개에 dev/store redirect URI 둘 다 등록 → 단일 client_id 사용.
# 비어있으면 OAuth 버튼 비활성화.
VITE_ASANA_CLIENT_ID=

# ClickUp OAuth (proxy 경유, confidential. 토큰 만료 없음 → refresh 라우트 없음).
# App 1개에 dev/store redirect URI 둘 다 등록 → 단일 client_id 사용.
#   redirect URL (트레일링 슬래시 포함 exact match):
#   - dev:   https://dhmffogmoohdjficicjjfolcheklngfm.chromiumapp.org/
#   - store: https://ohakhekagkodklkickemonmifdcbhmig.chromiumapp.org/
# client_secret은 oauth-proxy Worker env(CLICKUP_CLIENT_SECRET)에만 두고 /clickup/token 라우트로 교환.
# 비어있으면 OAuth 버튼 비활성화, API 토큰(PAT) 인증만 가능.
VITE_CLICKUP_CLIENT_ID=

# Chrome Web Store BugShot 페이지 URL (빈 값이면 푸터에 링크 없이 텍스트만 표시)
VITE_WEBSTORE_URL=

# PostHog 익명 이슈 제출 집계.
# prod 데이터만 누적: VITE_POSTHOG_KEY(dev)는 비워두고 VITE_POSTHOG_KEY_PROD에만 키를 넣는다.
# - 일반/dev 빌드: VITE_POSTHOG_KEY(비어 있으면 전송 no-op)
# - BUGSHOT_STORE_BUILD=1: VITE_POSTHOG_KEY_PROD가 빌드 시점에 VITE_POSTHOG_KEY로 define-치환.
# VITE_POSTHOG_HOST 기본값 https://us.i.posthog.com (EU는 https://eu.i.posthog.com).
VITE_POSTHOG_KEY=
VITE_POSTHOG_KEY_PROD=
VITE_POSTHOG_HOST=
